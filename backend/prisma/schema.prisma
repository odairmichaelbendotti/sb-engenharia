generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MASTER
  EDITOR
  USER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Company {
  id                String   @id @default(uuid())
  name              String
  cnpj              String   @unique
  cep               String
  city              String
  state             String
  address           String
  phone             String
  email             String
  hasActiveContract Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())

  empenhos    Empenho[]
  notasFicais NotaFiscal[]
}

enum EmpenhoStatus {
  ATIVO
  FINALIZADO
  CANCELADO
}

model Empenho {
  id          String        @id @default(uuid())
  numero      String        @unique
  description String
  startAt     DateTime
  endAt       DateTime
  value       Int
  totalPaid   Int           @default(0)
  status      EmpenhoStatus @default(ATIVO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())

  company_id  String
  company     Company      @relation(fields: [company_id], references: [id])
  notaFiscals NotaFiscal[]
}

enum NotaFiscalStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

model NotaFiscal {
  id          String           @id @default(uuid())
  numero      String
  description String
  vencimento  DateTime
  value       Int
  status      NotaFiscalStatus @default(PENDENTE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())

  empenho_id String
  empenho    Empenho @relation(fields: [empenho_id], references: [id], onDelete: Cascade)

  company_id String
  company    Company @relation(fields: [company_id], references: [id])
}
